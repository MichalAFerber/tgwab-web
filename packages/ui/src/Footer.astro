---
interface Props {
  productName?: string;
}
const { productName } = Astro.props;
---

<footer class="tgwab-footer">
  <div class="container tgwab-footer__inner">
    <div class="tgwab-footer__brand">
      {productName ? (
        <>
          <strong>{productName}</strong> —
          <a href="https://techguywithabeard.com">A TechGuyWithABeard product</a>
        </>
      ) : (
        <span>© {new Date().getFullYear()} Michal Ferber</span>
      )}
    </div>
    <nav class="tgwab-footer__links">
      <a href="https://techguywithabeard.com/">Home</a>
      <a href="https://techguywithabeard.com/portfolio/">Portfolio</a>
      <a href="https://techguywithabeard.com/blog/">Blog</a>
      <a href="https://techguywithabeard.com/wiki/">Wiki</a>
      <a href="https://techguywithabeard.com/search/">Search</a>
    </nav>
  </div>
</footer>

<style>
  .tgwab-footer {
    margin-top: var(--space-24);
    padding: var(--space-8) 0;
    border-top: 1px solid var(--color-border);
    background: var(--color-surface);
    font-size: var(--text-sm);
    color: var(--color-muted);
  }
  .tgwab-footer__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-4);
  }
  .tgwab-footer__links {
    display: flex;
    gap: var(--space-6);
  }
</style>
