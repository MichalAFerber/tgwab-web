---
import Layout from "@tgwab/ui/Layout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="Blog — TechGuyWithABeard">
  <div class="container">
    <h1>Blog</h1>
    <ul class="post-list">
      {posts.map((post) => (
        <li>
          <a href={`/blog/${post.slug}/`} class="post-list__link">
            {post.data.heroImage && (
              <img class="post-list__thumb" src={post.data.heroImage} alt="" loading="lazy" />
            )}
            <div class="post-list__body">
              <time datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}
              </time>
              <h2>{post.data.title}</h2>
              <p>{post.data.description}</p>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </div>
</Layout>

<style>
  .post-list { list-style: none; padding: 0; margin-top: var(--space-6); }
  .post-list li {
    border-bottom: 1px solid var(--color-border);
  }
  .post-list__link {
    display: flex;
    gap: var(--space-6);
    padding: var(--space-6) 0;
    text-decoration: none;
    color: inherit;
    align-items: flex-start;
  }
  .post-list__link:hover h2 { color: var(--tgwab-red); }
  .post-list__thumb {
    width: 180px;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    border-radius: var(--radius);
    background: var(--color-surface);
    flex-shrink: 0;
  }
  .post-list__body { flex: 1; min-width: 0; }
  .post-list time { font-size: var(--text-sm); color: var(--color-muted); }
  .post-list h2 {
    margin: var(--space-2) 0;
    color: var(--color-ink);
    transition: color 0.15s;
  }
  .post-list p { margin: 0; color: var(--color-muted); }

  @media (max-width: 640px) {
    .post-list__link { flex-direction: column; gap: var(--space-3); }
    .post-list__thumb { width: 100%; aspect-ratio: 16 / 9; }
  }
</style>
