---
import Layout from "@tgwab/ui/Layout.astro";
---

<Layout title="404 — TechGuyWithABeard" description="This page doesn't exist.">
  <div class="container fourohfour">
    <p class="code">404</p>
    <h1>Broken link. Or a typo. Or a dead domain.</h1>
    <p>Whatever it was, it's not here anymore.</p>
    <div class="cta">
      <a href="/" class="btn btn--primary">Home</a>
      <a href="/blog/" class="btn">Blog</a>
      <a href="/portfolio/" class="btn">Portfolio</a>
      <a href="/wiki/" class="btn">Wiki</a>
      <a href="/search/" class="btn">Search</a>
    </div>
  </div>
</Layout>

<style>
  .fourohfour {
    padding: var(--space-24) 0;
    text-align: center;
  }
  .code {
    font-family: var(--font-mono);
    font-size: var(--text-4xl);
    color: var(--tgwab-red);
    margin: 0 0 var(--space-4);
    letter-spacing: -0.02em;
  }
  .fourohfour h1 {
    max-width: 40ch;
    margin: 0 auto var(--space-4);
  }
  .fourohfour p {
    color: var(--color-muted);
    margin-bottom: var(--space-12);
  }
  .cta {
    display: flex;
    gap: var(--space-3);
    justify-content: center;
    flex-wrap: wrap;
  }
  .btn {
    display: inline-block;
    padding: var(--space-3) var(--space-6);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    text-decoration: none;
    color: var(--color-ink);
    background: var(--color-surface);
    font-size: var(--text-sm);
  }
  .btn:hover { border-color: var(--tgwab-red); color: var(--tgwab-red); }
  .btn--primary {
    background: var(--tgwab-red);
    color: white;
    border-color: var(--tgwab-red);
  }
  .btn--primary:hover { background: var(--tgwab-red-dark); color: white; border-color: var(--tgwab-red-dark); }
</style>
