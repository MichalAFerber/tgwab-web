---
import Layout from "@tgwab/ui/Layout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const entries = await getCollection("wiki", ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Layout title={`${entry.data.title} — Wiki`} description={entry.data.description || entry.data.title}>
  <article class="container" data-pagefind-body>
    <nav class="breadcrumb">
      <a href="/wiki/">Wiki</a>
      {entry.slug.split("/").slice(0, -1).map((part, i, arr) => {
        const href = "/wiki/" + arr.slice(0, i + 1).join("/") + "/";
        return <><span class="sep">/</span><a href={href}>{part}</a></>;
      })}
    </nav>
    <header>
      <h1>{entry.data.title}</h1>
      {entry.data.description && <p class="lede">{entry.data.description}</p>}
    </header>
    <Content />
  </article>
</Layout>

<style>
  .breadcrumb {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-muted);
    padding: var(--space-6) 0 var(--space-3);
  }
  .breadcrumb a { color: var(--color-muted); text-decoration: none; }
  .breadcrumb a:hover { color: var(--tgwab-red); }
  .breadcrumb .sep { margin: 0 var(--space-2); opacity: 0.5; }
  article header {
    padding: var(--space-6) 0 var(--space-8);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-8);
  }
  article header h1 { margin: 0 0 var(--space-3); }
  article header .lede {
    font-size: var(--text-lg);
    color: var(--color-muted);
    margin: 0;
  }
  article :global(h2) { margin-top: var(--space-12); }
  article :global(h3) { margin-top: var(--space-8); }
</style>
