---
import Layout from "@tgwab/ui/Layout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const slugifyTag = (tag) =>
    tag.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "");
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  const byTag = new Map();
  for (const post of posts) {
    for (const tag of post.data.tags ?? []) {
      const key = slugifyTag(tag);
      if (!byTag.has(key)) byTag.set(key, { raw: tag, posts: [] });
      byTag.get(key).posts.push(post);
    }
  }
  return [...byTag.entries()].map(([slug, { raw, posts: postList }]) => ({
    params: { tag: slug },
    props: {
      tag: raw,
      posts: postList.sort(
        (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
      ),
    },
  }));
}

const { tag, posts } = Astro.props;
---

<Layout title={`#${tag} — TechGuyWithABeard`} description={`Posts tagged ${tag}.`}>
  <div class="container">
    <p class="back"><a href="/tags/">← All tags</a></p>
    <h1><span class="hash">#</span>{tag}</h1>
    <p class="lede">{posts.length} post{posts.length === 1 ? "" : "s"}.</p>

    <ul class="post-list">
      {posts.map((post) => (
        <li>
          <a href={`/blog/${post.slug}/`} class="post-list__link">
            {post.data.heroImage && (
              <img class="post-list__thumb" src={post.data.heroImage} alt="" loading="lazy" />
            )}
            <div class="post-list__body">
              <time datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}
              </time>
              <h2>{post.data.title}</h2>
              <p>{post.data.description}</p>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </div>
</Layout>

<style>
  .back { font-size: var(--text-sm); color: var(--color-muted); margin-top: var(--space-6); }
  .back a { color: var(--color-muted); text-decoration: none; }
  .back a:hover { color: var(--tgwab-red); }
  .hash { color: var(--tgwab-red); }
  .lede { color: var(--color-muted); font-size: var(--text-lg); margin-bottom: var(--space-6); }

  .post-list { list-style: none; padding: 0; }
  .post-list li { border-bottom: 1px solid var(--color-border); }
  .post-list__link {
    display: flex;
    gap: var(--space-6);
    padding: var(--space-6) 0;
    text-decoration: none;
    color: inherit;
    align-items: flex-start;
  }
  .post-list__link:hover h2 { color: var(--tgwab-red); }
  .post-list__thumb {
    width: 180px;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    border-radius: var(--radius);
    background: var(--color-surface);
    flex-shrink: 0;
  }
  .post-list__body { flex: 1; min-width: 0; }
  .post-list time { font-size: var(--text-sm); color: var(--color-muted); }
  .post-list h2 { margin: var(--space-2) 0; }
  .post-list p { margin: 0; color: var(--color-muted); }

  @media (max-width: 640px) {
    .post-list__link { flex-direction: column; gap: var(--space-3); }
    .post-list__thumb { width: 100%; aspect-ratio: 16 / 9; }
  }
</style>
