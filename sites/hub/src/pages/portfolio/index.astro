---
import Layout from "@tgwab/ui/Layout.astro";
import { getCollection } from "astro:content";

const all = (await getCollection("wiki", ({ data }) => data.portfolio && !data.draft));

const groupOrder = ["chrome-extension", "script", "website", "service", "other"];
const groupLabel: Record<string, string> = {
  "chrome-extension": "Chrome Extensions",
  "script": "Scripts",
  "website": "Websites",
  "service": "Services",
  "other": "Other",
};

const grouped = groupOrder
  .map((cat) => ({
    category: cat,
    label: groupLabel[cat],
    items: all
      .filter((p) => p.data.portfolioCategory === cat)
      .sort((a, b) => (a.data.tier ?? 9) - (b.data.tier ?? 9) || (a.data.portfolioName ?? a.data.title).localeCompare(b.data.portfolioName ?? b.data.title)),
  }))
  .filter((g) => g.items.length > 0);
---

<Layout title="Portfolio — TechGuyWithABeard">
  <div class="container">
    <h1>Portfolio</h1>
    <p class="lede">Everything I've shipped or am actively building, grouped by type. Each card links to the wiki entry.</p>

    {grouped.map((group) => (
      <section class="group">
        <h2>{group.label}</h2>
        <ul class="card-grid">
          {group.items.map((entry) => (
            <li class="card">
              <div class="card__header">
                <h3>
                  <a href={`/wiki/${entry.slug}/`}>{entry.data.portfolioName ?? entry.data.title}</a>
                </h3>
                {entry.data.status && (
                  <span class={`status status--${entry.data.status}`}>{entry.data.status}</span>
                )}
              </div>
              {entry.data.tagline && <p class="card__tagline">{entry.data.tagline}</p>}
              {entry.data.description && <p class="card__desc">{entry.data.description}</p>}
              <div class="card__meta">
                {entry.data.url ? (
                  <a href={entry.data.url} target="_blank" rel="noopener noreferrer" class="card__visit">Visit →</a>
                ) : <span></span>}
                <span>{entry.data.tier ? `T${entry.data.tier}` : ""}{entry.data.revenue ? ` · ${entry.data.revenue}` : ""}</span>
              </div>
            </li>
          ))}
        </ul>
      </section>
    ))}
  </div>
</Layout>

<style>
  .lede { color: var(--color-muted); font-size: var(--text-lg); margin-bottom: var(--space-12); }
  .group { margin-bottom: var(--space-16); }
  .group h2 {
    font-family: var(--font-display);
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-border);
  }
  .card-grid {
    list-style: none; padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: var(--space-6);
  }
  .card {
    padding: var(--space-6);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-surface);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .card__header {
    display: flex; justify-content: space-between; align-items: baseline;
    gap: var(--space-3);
  }
  .card__header h3 { margin: 0; font-size: var(--text-xl); }
  .card__header h3 a { color: var(--color-ink); text-decoration: none; }
  .card__header h3 a:hover { color: var(--tgwab-red); }
  .card__tagline { margin: 0; font-size: var(--text-base); color: var(--color-ink); }
  .card__desc { margin: 0; font-size: var(--text-sm); color: var(--color-muted); flex: 1; }
  .card__meta {
    display: flex; justify-content: space-between; align-items: center;
    font-size: var(--text-xs); color: var(--color-muted);
    margin-top: var(--space-2);
  }
  .card__visit { color: var(--tgwab-red); text-decoration: none; }
  .status {
    font-size: var(--text-xs);
    text-transform: uppercase;
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
    letter-spacing: 0.05em;
    flex-shrink: 0;
  }
  .status--live { background: rgb(34 197 94 / 0.12); color: var(--color-green); border: 1px solid rgb(34 197 94 / 0.25); }
  .status--beta { background: rgb(240 165 0 / 0.12); color: var(--color-gold); border: 1px solid rgb(240 165 0 / 0.25); }
  .status--planning { background: rgb(59 130 246 / 0.12); color: var(--color-blue); border: 1px solid rgb(59 130 246 / 0.25); }
  .status--paused { background: rgb(107 114 128 / 0.12); color: var(--color-muted); border: 1px solid rgb(107 114 128 / 0.25); }
</style>
