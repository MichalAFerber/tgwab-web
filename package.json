{
  "name": "tgwab-web",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "dev:hub": "pnpm --filter @tgwab/hub dev",
    "build:hub": "pnpm --filter @tgwab/hub build",
    "preview:hub": "pnpm --filter @tgwab/hub preview",
    "build": "pnpm -r build",
    "migrate:blog": "node scripts/migrate-blog.mjs",
    "migrate:wiki": "node scripts/migrate-wiki.mjs",
    "migrate": "pnpm migrate:blog && pnpm migrate:wiki"
  },
  "packageManager": "pnpm@9.0.0"
}
